<styles:CustomDialogWindow x:Class="Sai2Capture.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:styles="clr-namespace:Sai2Capture.Styles"
        xmlns:local="clr-namespace:Sai2Capture.Views"
        mc:Ignorable="d"
        Title="确认操作" Height="200" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 消息内容 -->
        <Border Grid.Row="0" Margin="20,16">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="MessageText"
                           Text="确定要执行此操作吗？"
                           FontSize="14"
                           Foreground="#333333"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock x:Name="SubMessageText"
                           FontSize="12"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
            <ui:Button x:Name="ConfirmButton"
                       Content="确定"
                       Appearance="Primary"
                       Width="80"
                       Margin="0,0,12,0"
                       Click="ConfirmButton_Click"/>
            
            <ui:Button Content="取消"
                       Appearance="Secondary"
                       Width="80"
                       Margin="12,0,0,0"
                       Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</styles:CustomDialogWindow>
