<UserControl x:Class="Sai2Capture.Views.RecordingManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:Sai2Capture.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:UniversalConverter x:Key="UniversalConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <ui:Card Grid.Row="0" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="录制文件管理"
                               Style="{StaticResource CardTitleStyle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="16,0,0,0"
                               FontSize="{StaticResource FontSizeNormal}"
                               Foreground="{DynamicResource ui:BodyForegroundSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="🔄 刷新列表"
                               Command="{Binding RefreshFileListCommand}"
                               Appearance="Primary"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- 录制文件列表 -->
        <ui:Card Grid.Row="1" Margin="0,0,0,16">
            <Grid>
                <DataGrid
                          ItemsSource="{Binding VideoFiles}"
                          SelectedItem="{Binding SelectedVideo}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="Transparent">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Background" Value="{DynamicResource ui:CardBackgroundFillColorDefaultBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ui:BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ui:AccentFillColorDefaultBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名"
                                            Binding="{Binding FileName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="创建时间"
                                            Binding="{Binding CreatedTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Width="140"/>
                        <DataGridTextColumn Header="修改时间"
                                            Binding="{Binding ModifiedTime, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Width="140"/>
                        <DataGridTextColumn Header="文件大小"
                                            Binding="{Binding SizeDisplay}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 空状态提示 -->
                <Grid Visibility="{Binding VideoFiles.Count, Converter={StaticResource UniversalConverter}, ConverterParameter=IntToCollapsed}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32">
                        <TextBlock Text="📼"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="暂无视频文件"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ui:BodyForegroundSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="录制文件将保存在主页面设置的输出目录中"
                                   FontSize="13"
                                   Foreground="{DynamicResource ui:BodyForegroundSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ui:Card>

        <!-- 操作按钮 -->
        <ui:Card Grid.Row="2" Margin="0,0,0,16"
                 Visibility="{Binding SelectedVideo, Converter={StaticResource UniversalConverter}, ConverterParameter=NullToCollapsed}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:Button Content="▶️ 播放"
                           Command="{Binding OpenVideoCommand}"
                           Appearance="Primary"
                           Width="100"
                           Margin="0,0,12,0"/>

                <ui:Button Content="📂 打开位置"
                           Command="{Binding OpenFileLocationCommand}"
                           Width="100"
                           Margin="0,0,12,0"/>

                <ui:Button Content="🗑️ 删除"
                           Command="{Binding DeleteVideoCommand}"
                           Appearance="Danger"
                           Width="100">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>
        </ui:Card>
    </Grid>
</UserControl>
